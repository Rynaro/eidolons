{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rynaro/eidolons/schemas/aci.schema.json",
  "title": "Eidolons ACI Contract",
  "description": "Agent-Computer Interface contract (SWE-agent rubric, R8-02). Sibling to roster/index.yaml; consumed by the `eidolons doctor --deep` D7 gate.",
  "type": "object",
  "required": ["aci_version", "classes"],
  "additionalProperties": true,
  "properties": {
    "aci_version": { "type": "string" },
    "reference": { "type": "string" },
    "universal": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "reads_network": { "type": "boolean" }
      }
    },
    "classes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "read_only": { "type": "boolean" },
          "reads_repo": { "type": "boolean" },
          "tool_less": { "type": "boolean" },
          "requires_edit_gate": { "type": "boolean" },
          "exempt": { "type": "boolean" },
          "rationale": { "type": "string" },
          "bounded_primitives": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
