{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rynaro/eidolons/schemas/quality-suite.schema.json",
  "title": "Eidolons Quality Eval Suite",
  "description": "Human-in-the-loop contract-conformance quality benchmark, consumed by `eidolons eval quality`. Mechanical (grep) rubrics; no LLM-judge.",
  "type": "object",
  "required": ["quality_version", "tasks"],
  "additionalProperties": true,
  "properties": {
    "quality_version": { "type": "string" },
    "created_at": { "type": "string" },
    "grades": { "type": "string" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "eidolon", "mission", "rubric"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "eidolon": { "type": "string" },
          "mission": { "type": "string", "minLength": 1 },
          "rubric": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["must", "kind", "desc"],
              "additionalProperties": false,
              "properties": {
                "must": { "type": "boolean" },
                "kind": { "type": "string", "enum": ["contains_any", "contains_all", "regex", "min_count"] },
                "ci": { "type": "boolean" },
                "desc": { "type": "string" },
                "pattern": { "type": "string" },
                "patterns": { "type": "array", "items": { "type": "string" } },
                "n": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    }
  }
}
