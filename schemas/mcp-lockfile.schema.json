{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rynaro/eidolons/blob/main/schemas/mcp-lockfile.schema.json",
  "title": "eidolons.mcp.lock",
  "type": "object",
  "required": ["generated_at", "eidolons_cli_version", "mcps"],
  "properties": {
    "generated_at": { "type": "string", "format": "date-time" },
    "eidolons_cli_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+" },
    "catalogue_version": { "type": "string" },
    "mcps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "version", "source", "installed_at"],
        "properties": {
          "name":    { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "kind":    { "enum": ["oci-image", "binary", "script"] },
          "version": { "type": "string" },
          "source":  {
            "type": "object",
            "description": "Kind-specific source descriptor",
            "properties": {
              "image":    { "type": "string", "description": "oci-image: ghcr.io/foo/bar" },
              "repo":     { "type": "string", "description": "binary: GitHub owner/repo" },
              "url":      { "type": "string", "description": "script: download URL" }
            }
          },
          "integrity": {
            "type": "object",
            "required": ["algo", "value"],
            "properties": {
              "algo":  { "enum": ["sha256", "oci-digest", "none"] },
              "value": { "type": "string" }
            }
          },
          "target": { "type": "string", "description": "On-disk install path or marker file" },
          "hosts_wired": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Files that received marker-bounded sections (relative paths)."
          },
          "installed_at": { "type": "string", "format": "date-time" },
          "enforcement": {
            "enum": ["advisory", "block"],
            "description": "ESL escalation mode recorded by 'eidolons mcp assess' (the RECORD hop). Sticky, VCS-committed policy state; carried across reinstalls by mcp_lock_carry_enforcement."
          },
          "enforcement_signals": {
            "type": "object",
            "description": "Observable signals the assessment was computed from (e.g. file/contributor counts). Shape is owned by the assessed MCP's assess op."
          },
          "enforcement_thresholds": {
            "type": "object",
            "description": "Thresholds the signals were compared against when the enforcement mode was recorded."
          },
          "enforcement_assessed_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
