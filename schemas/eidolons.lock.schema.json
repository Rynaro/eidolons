{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rynaro/eidolons/blob/main/schemas/eidolons.lock.schema.json",
  "title": "eidolons.lock",
  "description": "Auto-generated lockfile recording resolved Eidolon versions. Commit to VCS.",
  "type": "object",
  "required": ["generated_at", "eidolons_cli_version", "members"],
  "properties": {
    "generated_at":            { "type": "string", "format": "date-time" },
    "eidolons_cli_version":    { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+" },
    "nexus_commit":            { "type": "string" },
    "hosts": {
      "type": "object",
      "description": "Mirrors the hosts configuration from eidolons.yaml at sync time for traceability.",
      "properties": {
        "wire":            { "type": "array", "items": { "type": "string" } },
        "shared_dispatch": { "type": "boolean" },
        "strict":          { "type": "boolean" },
        "pointer_targets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "context": {
      "type": "object",
      "description": "ECM P1 context-lifecycle kernel state, written by 'eidolons harness install' (GAP-003 resolved). Optional; absent means ECM is off for this project.",
      "properties": {
        "schema_version": { "type": "integer" },
        "ecm_version": { "type": "string" },
        "host_tier": { "type": "string" },
        "thresholds": {
          "type": "object",
          "properties": {
            "amber": { "type": "number" },
            "red": { "type": "number" },
            "critical": { "type": "number" }
          }
        },
        "compactthreshold_managed": { "type": "boolean" },
        "statusline_managed": {
          "type": "boolean",
          "description": "ecm-statusline-rollout: whether 'eidolons harness install' wrote (and owns) the claude-code statusLine key in .claude/settings.json (feeds ECM's rung-1 telemetry via 'eidolons statusline render'). false when claude-code is unwired, ECM is off, or a foreign statusLine was left don't-clobbered (AC-SL-2)."
        },
        "codex_autocompact_managed": {
          "type": "boolean",
          "description": "ECM P2 Track A/G: whether 'eidolons harness install' wrote (and owns) codex's model_auto_compact_token_limit config knob. false when codex is unwired, ECM is off, or a foreign value was left don't-clobbered (AC-CDX-7)."
        },
        "per_host": {
          "type": "object",
          "description": "ECM P2 Track G (AC-LK-1): per-host effective ECM tier/channel/features, one entry per wired host. Additive to host_tier (the pre-existing max-across-hosts field, retained unchanged).",
          "additionalProperties": {
            "type": "object",
            "required": ["tier", "channel"],
            "properties": {
              "tier": { "type": "string", "enum": ["T0", "T1", "T2", "T3"] },
              "channel": { "type": "string" },
              "ecm_features": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "resolved", "target"],
        "properties": {
          "name":     { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "version":  { "type": "string" },
          "resolved": { "type": "string", "description": "Source reference including commit SHA" },
          "commit":   { "type": "string", "pattern": "^(unknown|[0-9a-f]{40})$" },
          "tree":     { "type": "string", "pattern": "^$|^[0-9a-f]{40}$" },
          "archive_sha256":  { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
          "manifest_sha256": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
          "verification": {
            "type": "string",
            "enum": ["verified", "legacy-warning", "missing"]
          },
          "target":   { "type": "string" },
          "hosts_wired": {
            "type": "array",
            "items": { "enum": ["claude-code", "copilot", "cursor", "opencode", "codex", "raw"] }
          },
          "manifest_missing": { "type": "boolean" },
          "comm": {
            "type": "object",
            "description": "ECL communication metadata persisted from the roster at sync time. Optional.",
            "properties": {
              "envelope_version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
              }
            },
            "additionalProperties": false
          },
          "model": {
            "type": "object",
            "description": "Resolved model provenance for this member. Written by eidolons model / sync.",
            "additionalProperties": false,
            "required": ["effective_model", "tier", "profile", "source"],
            "properties": {
              "effective_model": { "type": "string", "minLength": 1 },
              "tier": { "type": "string", "enum": ["light", "standard", "deep"] },
              "profile": { "type": "string", "minLength": 1 },
              "source": {
                "type": "string",
                "enum": ["pin", "calibration", "profile", "roster-tier", "class-default"]
              }
            }
          }
        }
      }
    }
  }
}
