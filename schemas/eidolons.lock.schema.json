{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rynaro/eidolons/blob/main/schemas/eidolons.lock.schema.json",
  "title": "eidolons.lock",
  "description": "Auto-generated lockfile recording resolved Eidolon versions. Commit to VCS.",
  "type": "object",
  "required": ["generated_at", "eidolons_cli_version", "members"],
  "properties": {
    "generated_at":            { "type": "string", "format": "date-time" },
    "eidolons_cli_version":    { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+" },
    "nexus_commit":            { "type": "string" },
    "hosts": {
      "type": "object",
      "description": "Mirrors the hosts configuration from eidolons.yaml at sync time for traceability.",
      "properties": {
        "wire":            { "type": "array", "items": { "type": "string" } },
        "shared_dispatch": { "type": "boolean" },
        "strict":          { "type": "boolean" },
        "pointer_targets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "resolved", "target"],
        "properties": {
          "name":     { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "version":  { "type": "string" },
          "resolved": { "type": "string", "description": "Source reference including commit SHA" },
          "commit":   { "type": "string", "pattern": "^(unknown|[0-9a-f]{40})$" },
          "tree":     { "type": "string", "pattern": "^$|^[0-9a-f]{40}$" },
          "archive_sha256":  { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
          "manifest_sha256": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" },
          "verification": {
            "type": "string",
            "enum": ["verified", "legacy-warning", "missing"]
          },
          "target":   { "type": "string" },
          "hosts_wired": {
            "type": "array",
            "items": { "enum": ["claude-code", "copilot", "cursor", "opencode", "codex", "raw"] }
          },
          "manifest_missing": { "type": "boolean" },
          "comm": {
            "type": "object",
            "description": "ECL communication metadata persisted from the roster at sync time. Optional.",
            "properties": {
              "envelope_version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
              }
            },
            "additionalProperties": false
          },
          "model": {
            "type": "object",
            "description": "Resolved model provenance for this member. Written by eidolons model / sync.",
            "additionalProperties": false,
            "required": ["effective_model", "tier", "profile", "source"],
            "properties": {
              "effective_model": { "type": "string", "minLength": 1 },
              "tier": { "type": "string", "enum": ["light", "standard", "deep"] },
              "profile": { "type": "string", "minLength": 1 },
              "source": {
                "type": "string",
                "enum": ["pin", "calibration", "profile", "roster-tier", "class-default"]
              }
            }
          }
        }
      }
    }
  }
}
