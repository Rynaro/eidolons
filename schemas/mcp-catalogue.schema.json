{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rynaro/eidolons/blob/main/schemas/mcp-catalogue.schema.json",
  "title": "roster/mcps.yaml",
  "type": "object",
  "required": ["catalogue_version", "updated_at", "mcps"],
  "properties": {
    "catalogue_version": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" },
    "mcps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "display_name", "scope", "kind", "description", "source", "versions", "install", "health"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "display_name": { "type": "string" },
          "scope": { "enum": ["system", "eidolon:atlas", "eidolon:spectra", "eidolon:apivr", "eidolon:idg", "eidolon:forge", "eidolon:vigil"] },
          "kind": { "enum": ["oci-image", "binary", "script"] },
          "description": { "type": "string" },
          "use_cases": { "type": "array", "items": { "type": "string" } },
          "related_eidolons": { "type": "array", "items": { "type": "string" } },
          "grants_to_eidolons": {
            "description": "Machine-driven fanout: which installed Eidolons receive this MCP's tool surface. 'all' = every installed Eidolon; array = named subset; absent or [] = no fanout.",
            "oneOf": [
              { "type": "string", "enum": ["all"] },
              { "type": "array", "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" } }
            ]
          },
          "wiring_mode": {
            "description": "How this MCP's tool surface is delivered. 'allowlist' (default): exposes_tools.glob is injected into granted Eidolons' tools: lines. 'transport': the MCP is a project-level bus registered in .mcp.json only; its tools are NEVER injected into agent allowlists — the orchestration layer dispatches over it.",
            "enum": ["allowlist", "transport"]
          },
          "exposes_tools": {
            "description": "Tool surface advertised by this MCP. glob is the wire form used by the wiring pass; list is the auditable enumeration for display.",
            "type": "object",
            "properties": {
              "glob": {
                "type": "string",
                "pattern": "^mcp__[a-z][a-z0-9_]*__\\*$",
                "description": "Glob pattern for all tools exposed by this MCP (e.g. mcp__junction__*)"
              },
              "list": {
                "type": "array",
                "items": { "type": "string", "pattern": "^mcp__[a-z][a-z0-9_]*__[a-z][a-z0-9_]*$" },
                "description": "Explicit enumeration of tool names (informational, shown in eidolons mcp show)"
              }
            },
            "anyOf": [
              { "required": ["glob"] },
              { "required": ["list"] }
            ]
          },
          "source": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "enum": ["ghcr", "github_release", "url"] },
              "image": { "type": "string" },
              "repo": { "type": "string" },
              "install_url": { "type": "string" },
              "url": { "type": "string" }
            }
          },
          "versions": {
            "type": "object",
            "required": ["latest", "pins"],
            "properties": {
              "latest": { "type": "string" },
              "pins": {
                "type": "object",
                "required": ["stable"],
                "properties": {
                  "stable": { "type": "string" }
                }
              },
              "releases": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "digest": { "type": "string" },
                    "archive_sha256": { "type": "string" },
                    "released_at": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "hosts_wired": { "type": "array", "items": { "type": "string" } },
              "template": { "type": "string" },
              "cache_path": { "type": "string" },
              "marker": { "type": "string" }
            }
          },
          "health": {
            "type": "object",
            "required": ["probes"],
            "properties": {
              "probes": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
