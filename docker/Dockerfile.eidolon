# Dockerfile.eidolon — Reusable fragment for Eidolon container images.
#
# Built by eidolon-release-template.yml in the nexus (Rynaro/eidolons).
# Ships into all six Eidolon images; never hand-copied into the six Eidolon repos.
#
# Satisfies the §5.11 Eidolon container image contract (Junction spec round 6).
# See: .spectra/plans/2026-05-13-ecl-harness.md §5.11
#
# Build context expected layout (provided by the template's build job):
#   agent.md             — from the Eidolon repo root
#   skills/              — from the Eidolon repo root
#   templates/           — from the Eidolon repo root (optional, copied if present)
#   schemas/             — from the Eidolon repo root
#   ECL_VERSION          — from the Eidolon repo root
#   EIIS_VERSION         — from the Eidolon repo root
#   bin/ecl-io-shim      — vendored from nexus into the build context by the template
#
# Required build args (passed by eidolon-release-template.yml):
#   EIDOLON_VERSION      — SemVer without leading v (e.g. "1.3.0")
#   EIDOLON_NAME         — lowercase slug (e.g. "atlas")
#   EIDOLON_REPO         — GitHub repo slug (e.g. "Rynaro/ATLAS")
#   EIDOLON_REVISION     — git commit SHA at release time
#   ECL_VERSION          — ECL spec version (e.g. "1.0")
#   EIIS_VERSION         — EIIS spec version (e.g. "1.1")
#
# Security properties (§5.11):
#   - USER 65532:65532 — non-root; Junction's root-refusal gate never fires
#   - No API-key passthrough (NG18) — zero code path calling an LLM
#   - --network none safe in both phases (NG17 / OQ-18)

# Pin debian:bookworm-slim to an immutable digest (OQ-19 / AU16 linked set).
# Update this digest when the base image is re-scanned or a CVE patch lands.
# To find the current digest: docker manifest inspect debian:bookworm-slim
# Pinned 2026-05-14; SHA256 of amd64 debian:bookworm-slim 12 (2024-09-09 release).
FROM debian:bookworm-slim@sha256:27bdad58f618f8d44a5c5d9a49ddc16b3dea476e5c76a76b9c900f89d6dde3ef

# ── Build arguments ───────────────────────────────────────────────────────────
ARG EIDOLON_NAME="unknown"
ARG EIDOLON_VERSION="0.0.0"
ARG EIDOLON_REPO=""
ARG EIDOLON_REVISION=""
ARG ECL_VERSION="1.0"
ARG EIIS_VERSION="1.1"

# ── Install required tools ────────────────────────────────────────────────────
# bash, jq, coreutils (sha256sum) — the only tools the ecl-io-shim needs.
# Clean apt layer in one RUN to minimize image size.
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
       bash \
       jq \
       coreutils \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

# ── Bake-in the Eidolon manifest (§5.11 required layout) ─────────────────────
# All paths relative to build context root (set by the template's build job).
# templates/ is optional in the spec but COPY will succeed if absent from context
# only if we use a wildcard or conditional — we use a multi-stage approach below.
COPY agent.md /eidolon/
COPY schemas/ /eidolon/schemas/
COPY ECL_VERSION /eidolon/ECL_VERSION
COPY EIIS_VERSION /eidolon/EIIS_VERSION

# skills/ and templates/ may be absent in minimal Eidolon repos; use || true
# via a RUN fallback is not clean Dockerfile style — use COPY with a glob:
# If the directory doesn't exist in the build context the build will fail,
# which is the correct behaviour (conformant Eidolons MUST have skills/).
COPY skills/ /eidolon/skills/

# templates/ is optional; the Dockerfile makes a best-effort COPY.
# When absent from context: the template's build job creates an empty sentinel.
COPY templates/ /eidolon/templates/

# ── Vendor ecl-io-shim (from nexus build context) ────────────────────────────
# The template's build job fetches bin/ecl-io-shim from the nexus checkout
# into the build context before running docker build. Never hand-copied.
COPY bin/ecl-io-shim /eidolon/bin/ecl-io-shim
RUN chmod +x /eidolon/bin/ecl-io-shim

# ── Non-root user (§5.11: USER 65532:65532) ──────────────────────────────────
# UID/GID 65532 is the conventional "nonroot" user from distroless.
RUN groupadd --gid 65532 nonroot \
  && useradd --uid 65532 --gid 65532 --no-create-home --shell /bin/false nonroot

USER 65532:65532

# ── OCI labels (§5.11) ───────────────────────────────────────────────────────
# Standard OCI image labels
LABEL org.opencontainers.image.source="https://github.com/${EIDOLON_REPO}"
LABEL org.opencontainers.image.version="${EIDOLON_VERSION}"
LABEL org.opencontainers.image.revision="${EIDOLON_REVISION}"
# Eidolons-specific labels
LABEL dev.eidolons.ecl-version="${ECL_VERSION}"
LABEL dev.eidolons.eiis-version="${EIIS_VERSION}"
LABEL dev.eidolons.junction-contract="1"
LABEL dev.eidolons.phases="assemble,package"

# ── ENTRYPOINT (§5.11: self-dispatches on JUNCTION_PHASE) ────────────────────
ENTRYPOINT ["/eidolon/bin/ecl-io-shim"]
# No CMD — JUNCTION_PHASE env var drives dispatch.
