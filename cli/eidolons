#!/usr/bin/env bash
#
# eidolons — personal team of AI agents, for any project
# ═══════════════════════════════════════════════════════════════════════════

set -euo pipefail

EIDOLONS_HOME="${EIDOLONS_HOME:-$HOME/.eidolons}"
NEXUS="${EIDOLONS_NEXUS:-$EIDOLONS_HOME/nexus}"
CLI_SRC="$NEXUS/cli/src"
CLI_LIB="$NEXUS/cli/src/lib.sh"

# Resolve the dispatch source: find the directory that contains the full
# CLI src tree.  Priority:
#  1. NEXUS/cli/src when it has upgrade.sh (normal installed or dev case).
#  2. The directory containing this script (resolves symlinks) when NEXUS
#     does not have the full src tree — handles test fixtures that set
#     EIDOLONS_NEXUS to a minimal roster-only dir.
if [[ ! -f "$CLI_SRC/upgrade.sh" ]]; then
  SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}")"
  NEXUS="$(dirname "$(dirname "$SELF")")"
  CLI_SRC="$NEXUS/cli/src"
  CLI_LIB="$NEXUS/cli/src/lib.sh"
  unset SELF
fi

# Read version from VERSION file at nexus root; fall back to git describe,
# then to the embedded constant (dev checkouts without a VERSION file).
_read_nexus_version() {
  local _vfile="$NEXUS/VERSION"
  if [[ -f "$_vfile" ]]; then
    tr -d '[:space:]' < "$_vfile"
    return 0
  fi
  local _gdesc
  _gdesc="$(git -C "$NEXUS" describe --tags --abbrev=0 2>/dev/null || true)"
  if [[ -n "$_gdesc" ]]; then
    echo "${_gdesc#v}"
    return 0
  fi
  echo "0.0.0-dev"
}

EIDOLONS_VERSION="$(_read_nexus_version)"
export EIDOLONS_VERSION

if [[ -f "$CLI_SRC/ui/panel.sh" ]]; then
  # shellcheck disable=SC1091
  . "$CLI_SRC/ui/theme.sh"
  # shellcheck disable=SC1091
  . "$CLI_SRC/ui/panel.sh"
fi

usage() {
  # Banner prints to stderr and is silent in plain mode — keeps `eidolons
  # help | grep ...` and the bats suite (non-TTY) seeing exactly what
  # they always saw. Stdout below is the actual help text.
  if command -v ui_banner >/dev/null 2>&1; then
    ui_banner "$EIDOLONS_VERSION"
  fi
  cat <<EOF
eidolons v${EIDOLONS_VERSION} — personal team of AI agents for any project

Usage: eidolons <command> [options]

Commands:
  init           Initialize a project with Eidolons (greenfield or brownfield)
  add            Add one or more Eidolons to this project
  remove         Remove an Eidolon from this project
  sync           Install/update to match eidolons.yaml (idempotent)
  list           List available (from roster) or installed Eidolons
  roster         Show detailed roster information
  model <sub>    Vendor-neutral model management. Subcommands:
                   list                     List profiles + tier ladder
                   show [<eidolon>]         Show resolved models (table or --json)
                   use <eidolon>@<t|model>  Set tier override or concrete model pin
                   profile <name>           Switch active profile; rewrites frontmatter
                   reset [<eidolon>]        Clear overrides (one member or all)
                 Run 'eidolons model --help' for full usage.
  run            Deterministically route a prompt to the correct Eidolon(s)
                 (mechanical cortex dispatch over roster/routing.yaml; no LLM)
  trace <sub>    Read ECL hand-off telemetry. Subcommands:
                   show <path...>               render the hand-off chain
                   graph <path...>              render the hand-off DAG
                   verify <path...> [--block]   batch SHA-256 integrity check
                   cost <path...> [--budget N]  per-Eidolon token attribution
                   otel <path...>               emit OpenTelemetry GenAI spans
  eval <sub>     Measure the Eidolons against labelled ground truth (no LLM):
                   routing [--suite ...] [--min N]   deterministic routing benchmark
                   quality emit|grade <task> ...     human-in-the-loop quality (pass^k)
  sandbox <sub>  Bounded, delegated edit-run-test loop (adapter, not an engine):
                   check / run / loop  — delegates isolation (--via) + edits
                   (--fix-hook); diff-not-apply; VIGIL hand-off on cap-out
                   replay <out_dir>    read-only render of a completed loop's
                   artifacts; SHA-256 integrity verify; pass^k report; no re-exec
  doctor         Health-check installed Eidolons and host wiring
  migrate-stamp  Rewrite eidolons.yaml/eidolons.lock version stamps to current nexus VERSION
  nexus <sub>    Inspect and control the nexus roster channel. Subcommands:
                   refresh [--quiet]        Force roster data refresh now
                   channel [<ref>]          Get or set roster channel
                   status                   Show CLI pin vs roster channel + freshness
                 Run 'eidolons nexus --help' for full usage.
  mcp <sub>      MCP server store. Subcommands:
                   list                     List catalogue MCPs with status
                   show <name>              Show MCP details
                   install <name>[@<ver>]   Install an MCP (idempotent)
                   refresh <name>           Re-fetch artefact (image/binary)
                   uninstall <name>         Remove from this project
                   upgrade [<name>|--all]   Upgrade to catalogue stable
                   use <name>@<ver>         Switch to a published version
                   assess <name>            Record ESL escalation into the lock
                   sync                     Reconcile eidolons.yaml mcps: block
                   health [<name>|--all]    Run health probes
                   run <name> [<args>]      Pass-through to runnable MCP binary
                 Run 'eidolons mcp --help' for full usage.
  memory <sub>   Mechanical memory pre-flight (GAP-2). Subcommands:
                   preflight [--query --ttl --no-cache --timeout]
                             One-shot crystalium recall; emits compact digest.
                             Stdout IS the digest; all failures = empty/exit-0.
                 Run 'eidolons memory --help' for full usage.
  context <sub> Deterministic context-lifecycle kernel (ECM P1, opt-in). Subcommands:
                   status       Write .eidolons/.context/meter.json (D1 3-rung ladder)
                   policy       Evaluate roster/context-policy.yaml over the meter
                   externalize  Checkpoint identifiers to crystalium (file-floor fallback)
                   handoff      Compose a session handoff brief + ECL envelope
                 Run 'eidolons context --help' for full usage.
  telemetry <sub> Opt-in token-cost telemetry (audited spend, not estimated).
                   capture --hook STOP_<HOST> --stdin   Capture turn rows at session Stop
                   rollup  [--by ...] [--since ...]     Pure-jq M1/M2/M3 aggregation (Phase D)
                   report  [--project] [--since] [--json] Human dashboard, source-split (Phase D)
                   enable                               Write Stop shim + hook registration (Phase F)
                   disable                              Remove Stop shim + hook entry (Phase F)
                 Run 'eidolons telemetry --help' for full usage.
  harness <sub>  Wire host hooks for routing-context injection (claude-code, codex).
                   install [--hosts <h>]   Install hook shims + settings wiring
                   remove                  Remove hook shims + settings wiring
                   status                  Show wired hosts, tier, and shim paths
                 Legacy aliases (deprecated, removal v3.0.0):
                   up|verify|uninstall     Delegate to 'eidolons mcp <verb> junction'
                 Run 'eidolons harness --help' for full usage.
  verify         Verify installed Eidolon release integrity
  verify-release Layer 2 integrity: compare installed Eidolons against
                 fresh re-derivation from upstream-pinned release
  verify-envelope Mechanically verify an ECL hand-off envelope's SHA-256
                 (deterministic gate; warn|block mode; no LLM)
  canary         Layer 3 integrity: print canary prompt or validate LLM output
                 against an Eidolon's per-version canary mission.
                 Run 'eidolons canary --help' for modes.
  upgrade        Upgrade pinned Eidolon versions (or 'upgrade self' to upgrade the CLI)
  release        One-touch Eidolon release + Roster Intake (maintainer-only)
  <eidolon> <sub>  Run a per-Eidolon subcommand (e.g. 'eidolons spectra fit').
                 Each Eidolon exposes its own subcommands via
                 .eidolons/<eidolon>/commands/*.sh after install.
                 Run 'eidolons <eidolon> --help' to list available ones.
  version        Print CLI version
  help           Show this help

Options common to all commands:
  -h, --help           Show command-specific help
  --nexus DIR          Override nexus path (default: \$EIDOLONS_HOME/nexus)
  --non-interactive    Fail on prompts (for CI / scripted use)
  -v, --verbose        Verbose output

Environment:
  EIDOLONS_HOME                   Nexus cache location (default: ~/.eidolons)
  EIDOLONS_SUPPRESS_DEPRECATED=1  Suppress DEPRECATED lines from legacy verbs

Docs:       $NEXUS/docs/
Nexus repo: https://github.com/Rynaro/eidolons

Run 'eidolons <command> --help' for command-specific help.
EOF
}

# _deprecated_alias OLD_VERB NEW_VERB
# Emits a DEPRECATED warning to stderr unless EIDOLONS_SUPPRESS_DEPRECATED=1.
_deprecated_alias() {
  local old="$1" new="$2"
  if [ "${EIDOLONS_SUPPRESS_DEPRECATED:-0}" = "1" ]; then
    return 0
  fi
  printf 'DEPRECATED: %s is deprecated. Use %s instead. (Removal: v3.0.0.)\n' \
    "$old" "$new" >&2
}

cmd="${1:-help}"
[[ $# -gt 0 ]] && shift

case "$cmd" in
  init)        exec bash "$CLI_SRC/init.sh"    "$@" ;;
  add)         exec bash "$CLI_SRC/add.sh"     "$@" ;;
  remove|rm)   exec bash "$CLI_SRC/remove.sh"  "$@" ;;
  sync)        exec bash "$CLI_SRC/sync.sh"    "$@" ;;
  list|ls)     exec bash "$CLI_SRC/list.sh"    "$@" ;;
  roster)      exec bash "$CLI_SRC/roster.sh"  "$@" ;;
  run)         exec bash "$CLI_SRC/run.sh"     "$@" ;;
  model)       exec bash "$CLI_SRC/model.sh"  "$@" ;;
  trace)       exec bash "$CLI_SRC/trace.sh"      "$@" ;;
  telemetry)   exec bash "$CLI_SRC/telemetry.sh" "$@" ;;
  eval)        exec bash "$CLI_SRC/eval.sh"       "$@" ;;
  sandbox)     exec bash "$CLI_SRC/sandbox.sh"    "$@" ;;
  doctor)        exec bash "$CLI_SRC/doctor.sh"         "$@" ;;
  migrate-stamp) exec bash "$CLI_SRC/migrate-stamp.sh"  "$@" ;;
  harness)
    _harness_sub="${1:-}"
    [ $# -gt 0 ] && shift
    case "$_harness_sub" in
      # ── New hook-wiring family ────────────────────────────────────────
      install)
        # Bare-semver arg (e.g. `harness install 0.3.0`) was the old
        # Junction-install form. Die with a migration hint.
        _harness_first="${1:-}"
        if [ -n "$_harness_first" ] && [ "${_harness_first#-}" = "$_harness_first" ] \
           && printf '%s' "$_harness_first" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+'; then
          if [ "${EIDOLONS_SUPPRESS_DEPRECATED:-0}" != "1" ]; then
            printf 'DEPRECATED: bare semver argument to `harness install` is no longer supported.\n' >&2
          fi
          printf 'Migration: eidolons mcp install junction@%s\n' "$_harness_first" >&2
          printf 'Note: `eidolons harness install` now wires host hooks; see `eidolons harness --help`.\n' >&2
          exit 1
        fi
        exec bash "$CLI_SRC/harness_install.sh" "$@"
        ;;
      remove)   exec bash "$CLI_SRC/harness_remove.sh"  "$@" ;;
      status)   exec bash "$CLI_SRC/harness_status.sh"  "$@" ;;
      # ── Legacy Junction aliases (deprecated; removal v3.0.0) ─────────
      up)
        _deprecated_alias "eidolons harness up" "eidolons mcp health junction"
        exec bash "$CLI_SRC/mcp_health.sh" "junction" "$@"
        ;;
      verify)
        _deprecated_alias "eidolons harness verify" "eidolons mcp run junction verify"
        exec bash "$CLI_SRC/mcp_run.sh" "junction" "verify" "$@"
        ;;
      uninstall)
        _deprecated_alias "eidolons harness uninstall" "eidolons mcp uninstall junction"
        exec bash "$CLI_SRC/mcp_uninstall.sh" "junction" "$@"
        ;;
      -h|--help|help)
        exec bash "$CLI_SRC/harness_install.sh" --help
        ;;
      "")
        exec bash "$CLI_SRC/harness_install.sh" --help
        ;;
      *)
        printf 'Unknown harness subcommand: %s\n' "$_harness_sub" >&2
        printf 'Available: install remove status (also: up verify uninstall [deprecated])\n' >&2
        exit 2
        ;;
    esac
    ;;
  nexus)       exec bash "$CLI_SRC/nexus.sh"         "$@" ;;
  verify)          exec bash "$CLI_SRC/verify.sh"          "$@" ;;
  verify-release)  exec bash "$CLI_SRC/verify_release.sh"  "$@" ;;
  verify-envelope) exec bash "$CLI_SRC/verify_envelope.sh" "$@" ;;
  canary)         exec bash "$CLI_SRC/canary.sh"         "$@" ;;
  release)     exec bash "$CLI_SRC/release.sh"   "$@" ;;
  upgrade)
    # Peek at the first remaining arg to decide which subcommand to dispatch.
    # If it's "self", consume it and dispatch to upgrade_self.sh.
    # Otherwise, pass all args to the existing upgrade.sh without modification.
    _upgrade_sub="${1:-}"
    case "$_upgrade_sub" in
      self) shift; exec bash "$CLI_SRC/upgrade_self.sh" "$@" ;;
      *)    exec bash "$CLI_SRC/upgrade.sh"             "$@" ;;
    esac
    ;;
  mcp)
    mcp_sub="${1:-}"
    [ $# -gt 0 ] && shift
    case "$mcp_sub" in
      # New unified verbs — delegate to mcp.sh sub-dispatcher.
      list|show|install|refresh|uninstall|upgrade|use|assess|sync|health|run|pull|images|-h|--help|help)
        exec bash "$CLI_SRC/mcp.sh" "$mcp_sub" "$@"
        ;;
      # Legacy deprecated alias: 'eidolons mcp atlas-aci [pull] [...]'
      atlas-aci)
        _sub2="${1:-}"
        case "$_sub2" in
          pull)
            shift
            # Re-pointed from mcp_refresh.sh → mcp_pull.sh (OQ-4).
            # Semantics change: lockfile-driven → catalogue-pin-driven.
            # The alias remains DEPRECATED; re-point is noted in CHANGELOG.
            _deprecated_alias "eidolons mcp atlas-aci pull" "eidolons mcp pull atlas-aci"
            exec bash "$CLI_SRC/mcp_pull.sh" "atlas-aci" "$@"
            ;;
          *)
            _deprecated_alias "eidolons mcp atlas-aci" "eidolons mcp install atlas-aci"
            exec bash "$CLI_SRC/mcp_install.sh" "atlas-aci" "$@"
            ;;
        esac
        ;;
      "")
        exec bash "$CLI_SRC/mcp.sh"
        ;;
      *)
        echo "Unknown mcp subcommand: $mcp_sub" >&2
        echo "" >&2
        echo "Run 'eidolons mcp --help' for available subcommands." >&2
        exit 2
        ;;
    esac
    ;;
  memory)
    _memory_sub="${1:-}"
    [ $# -gt 0 ] && shift
    case "$_memory_sub" in
      preflight) exec bash "$CLI_SRC/memory.sh" preflight "$@" ;;
      -h|--help|help|"") exec bash "$CLI_SRC/memory.sh" --help ;;
      *) printf 'Unknown memory subcommand: %s\n' "$_memory_sub" >&2
         printf 'Available: preflight\n' >&2; exit 2 ;;
    esac
    ;;
  context)      exec bash "$CLI_SRC/context.sh"    "$@" ;;
  version|--version|-v)
    # --quiet → single-line grep-compat form (legacy CI surface preserved)
    _quiet=false
    for _a in "$@"; do
      case "$_a" in --quiet|-q) _quiet=true ;; esac
    done
    if [[ "$_quiet" == true ]]; then
      echo "eidolons $EIDOLONS_VERSION"
    else
      _install_commit="$(cat "$NEXUS/.install_commit" 2>/dev/null || \
        git -C "$NEXUS" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
      _install_ref="$(cat "$NEXUS/.install_ref" 2>/dev/null || echo "unknown")"
      _install_date="$(cat "$NEXUS/.install_date" 2>/dev/null || echo "unknown")"
      echo "eidolons $EIDOLONS_VERSION"
      echo "  commit:       $_install_commit"
      echo "  ref:          $_install_ref"
      echo "  installed:    $_install_date"
      echo "  nexus path:   $NEXUS"
    fi
    ;;
  help|--help|-h|"")    usage ;;
  *)
    # Catch-all: if $cmd matches a roster Eidolon name, delegate to the
    # per-Eidolon subcommand dispatcher. Otherwise, unknown command.
    if bash -c ". '$CLI_LIB' && roster_list_names" 2>/dev/null | grep -Fxq "$cmd"; then
      exec bash "$CLI_SRC/dispatch_eidolon.sh" "$cmd" "$@"
    fi
    echo "Unknown command: $cmd" >&2
    echo "" >&2
    usage >&2
    exit 2
    ;;
esac
