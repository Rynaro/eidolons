{
  "mcpServers": {
    "atomos": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--label",
        "eidolons.project=__PROJECT_SLUG__",
        "-v",
        "__PROJECT_ROOT__:__PROJECT_ROOT__:z",
        "-w",
        "__PROJECT_ROOT__",
        "--cap-drop",
        "ALL",
        "--security-opt",
        "no-new-privileges",
        "ghcr.io/rynaro/atomos@__IMAGE_DIGEST__",
        "serve"
      ]
    }
  }
}
