{
  "mcpServers": {
    "atlas-aci": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--user",
        "__UID_GID__",
        "--read-only",
        "--label",
        "eidolons.project=__PROJECT_SLUG__",
        "-v",
        "__PROJECT_ROOT__:/repo:ro",
        "-v",
        "__PROJECT_ROOT__/.atlas/memex:/memex",
        "--cap-drop",
        "ALL",
        "--security-opt",
        "no-new-privileges",
        "ghcr.io/rynaro/atlas-aci@__IMAGE_DIGEST__",
        "serve",
        "--repo",
        "/repo",
        "--memex-root",
        "/memex"
      ]
    }
  }
}
